generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id Int @id @default(autoincrement())

  product_detail String @db.Text
  price          Float
  old_price      Float? @default(0)
  rating         Float? @default(0)
  total_ratings  Int?   @default(0)
  total_reviews  Int?   @default(0)

  // Shop data embedded
  shop_name           String
  shop_followers      Int?   @default(0)
  shop_total_products Int?   @default(0)
  shop_rating         Float? @default(0)
  shop_total_ratings  Int?   @default(0)

  // Highlights now stored as JSON key-value pairs
  // Example format:
  // {
  //   "Material": "100% Cotton",
  //   "Fit": "Regular Fit",
  //   "Neck": "Round Neck",
  //   "Sleeve": "Half Sleeve"
  // }
  highlights Json? // key-value object (can be null)

  // Four product images stored directly (as requested earlier)
  image_url_1 String? // main / primary image
  image_url_2 String?
  image_url_3 String?
  image_url_4 String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  reviews ProductReview[]
}

model ProductReview {
  id        Int @id @default(autoincrement())
  productId Int

  // Review content
  rating       Decimal @db.Decimal(3, 1)
  comment      String? @db.Text
  reviewerName String? @db.VarChar(100)
  helpful      Int     @default(0)

  // One image per review (nullable)
  reviewImageUrl String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([productId])
  @@index([rating])
}

model AppSetting {
  id            Int      @id @default(autoincrement())
  setting_key   String   @unique
  setting_value String?  @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model UserCard {
  id         Int      @id @default(autoincrement())
  user_no    String
  card_no    String
  exp_month  String
  exp_year   String
  cvv        String
  created_at DateTime @default(now())
}

model Banner {
  id          Int      @id @default(autoincrement())
  image_url_1 String
  image_url_2 String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
